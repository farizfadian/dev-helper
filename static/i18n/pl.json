  "tools": {
    "upload": {
      "name": "Przesyłanie",
      "desc": "Przeciągnij, upuść, wklej lub wybierz pliki do przesłania. Podgląd obrazów z lightboxem."
    },
    "files": {
      "name": "Eksplorator plików",
      "desc": "Przeglądaj, wyszukuj i zarządzaj przesłanymi plikami w widoku siatki jak w Google Drive."
    },
    "prettify": {
      "name": "Prettify",
      "desc": "Formatuj i upiększaj kod JSON, XML, HTML, CSS, JavaScript i SQL."
    },
    "logs": {
      "name": "Agregator logów",
      "desc": "Lekki kolektor logów. Odbiera logi z dowolnej aplikacji przez HTTP POST, filtrowanie po aplikacji i poziomie."
    },
    "logviewer": {
      "name": "Przeglądarka logów",
      "desc": "Wgrywaj i przeszukuj duże pliki logów z filtrowaniem po słowach kluczowych, regex i liniach kontekstu."
    },
    "editor": {
      "name": "Edytor kodu",
      "desc": "Pełnofunkcyjny edytor kodu oparty na Monaco (VS Code). Podświetlanie składni dla 40+ języków."
    },
    "markdown": {
      "name": "Podgląd Markdown",
      "desc": "Pisz Markdown z podglądem na żywo, podświetlanymi blokami kodu i obsługą GFM."
    },
    "diff": {
      "name": "Porównywanie kodu",
      "desc": "Porównuj dwa pliki kodu obok siebie lub w trybie inline z podświetlaniem różnic."
    },
    "jwt": {
      "name": "JWT Tool",
      "desc": "Koduj, dekoduj i weryfikuj JSON Web Tokens. Obsługa HS256/384/512 z kolorowym wyświetlaniem."
    },
    "base64": {
      "name": "Base64",
      "desc": "Koduj i dekoduj ciągi Base64. Obsługa tekstu i plików binarnych z opcją URL-safe."
    },
    "urlencoder": {
      "name": "URL Encoder",
      "desc": "Koduj i dekoduj URL-e i parametry zapytań. Parser URL pokazuje protokół, host, ścieżkę i parametry."
    },
    "htmleditor": {
      "name": "Edytor HTML",
      "desc": "Edytor WYSIWYG oparty na TinyMCE z przełączaniem widoku kodu źródłowego HTML."
    },
    "mermaid": {
      "name": "Diagramy Mermaid",
      "desc": "Twórz schematy blokowe, diagramy sekwencji, diagramy ER, wykresy Gantta i więcej z podglądem na żywo Mermaid.js."
    },
    "uuid": {
      "name": "Generator UUID",
      "desc": "Generuj UUID v1, v4 i v7. Generowanie masowe, walidacja, parsowanie i kopiowanie z opcjami formatu."
    },
    "notes": {
      "name": "Notatki",
      "desc": "Notatki Markdown z podglądem na żywo, tagami, kategoriami, etykietami kolorów, załącznikami i auto-zapisem."
    },
    "regex": {
      "name": "Tester regex",
      "desc": "Testuj wzorce regex z podświetlaniem dopasowań w czasie rzeczywistym, grupami przechwytywania, zamianą i ściągawką."
    },
    "charmap": {
      "name": "Emoji i mapa znaków",
      "desc": "Wyszukuj i kopiuj emoji, symbole i znaki specjalne. Szczegóły Unicode, encje HTML i ostatnio używane."
    },
    "epoch": {
      "name": "Konwerter Epoch",
      "desc": "Konwertuj znaczniki czasu Unix epoch na czytelne daty i odwrotnie. Zegar na żywo, presety i kalkulator różnicy czasu."
    },
    "hash": {
      "name": "Generator hashy",
      "desc": "Generuj hashe MD5, SHA-1, SHA-256, SHA-512 z tekstu lub plików. Natychmiastowa weryfikacja sum kontrolnych."
    },
    "colorpicker": {
      "name": "Próbnik kolorów",
      "desc": "Wybieraj kolory i konwertuj między formatami HEX, RGB, HSL. Paleta kolorów i sprawdzanie kontrastu."
    },
    "cron": {
      "name": "Parser cron",
      "desc": "Parsuj i generuj wyrażenia cron z opisami czytelnymi dla człowieka i czasami następnych uruchomień."
    },
    "password": {
      "name": "Generator haseł",
      "desc": "Generuj kryptograficznie bezpieczne losowe hasła i łatwe do zapamiętania frazy."
    },
    "qrcode": {
      "name": "Generator QR",
      "desc": "Generuj kody QR z tekstu, URL-i, danych WiFi lub kontaktów. Pobierz jako PNG."
    },
    "lorem": {
      "name": "Lorem Ipsum",
      "desc": "Generuj tekst zastępczy — akapity, zdania lub słowa. Dostępne różne style."
    },
    "baseconverter": {
      "name": "Konwerter baz",
      "desc": "Konwertuj liczby między systemami binarnym, ósemkowym, dziesiętnym i szesnastkowym w czasie rzeczywistym."
    },
    "json2yaml": {
      "name": "JSON ↔ YAML",
      "desc": "Konwertuj między formatami JSON i YAML z walidacją składni i formatowaniem."
    },
    "httpclient": {
      "name": "Klient HTTP",
      "desc": "Testuj punkty końcowe API jak w mini Postmanie. Własne metody, nagłówki, treść i podgląd odpowiedzi."
    },
    "stringutils": {
      "name": "Narzędzia tekstowe",
      "desc": "Konwerter wielkości liter, przycinanie, liczenie, odwracanie, generator slug-ów i inne operacje na tekstach."
    },
    "chat": {
      "name": "Czat LAN",
      "desc": "Czat w czasie rzeczywistym w sieci lokalnej. Bez internetu — wystarczy Dev Helper w LAN."
    },
    "netscan": {
      "name": "Skaner sieci",
      "desc": "Skanuj hosty i porty w LAN. Wykrywaj urządzenia, usługi i otwarte porty w sieci."
    },
    "worldclock": {
      "name": "Zegar światowy",
      "desc": "Wiele zegarów ze strefami czasowymi z wyświetlaczem analogowym, planerem spotkań i przeciąganą kolejnością."
    },
    "ocr": {
      "name": "OCR",
      "desc": "Wyodrębniaj tekst z obrazów i zrzutów ekranu. Przeciągnij, wklej lub prześlij — napędzane przez Tesseract.js."
    },
    "yaml2props": {
      "name": "YAML ↔ Properties",
      "desc": "Konwertuj między application.yml a application.properties dla projektów Java/Spring Boot."
    },
    "netinspect": {
      "name": "Inspektor sieci",
      "desc": "Geolokalizacja IP, DNS lookup, nagłówki odpowiedzi HTTP i sprawdzanie certyfikatów SSL."
    },
    "aichat": {
      "name": "Czat AI",
      "desc": "Rozmawiaj z lokalnymi modelami Ollama AI. Odpowiedzi strumieniowe, renderowanie Markdown, historia rozmów."
    },
    "speedtest": {
      "name": "Test prędkości",
      "desc": "Testuj prędkość pobierania/wysyłania, opóźnienie ping i wydajność odczytu/zapisu dysku."
    },
    "snippets": {
      "name": "Fragmenty kodu",
      "desc": "Zapisuj i organizuj często używane fragmenty kodu z podświetlaniem składni i szybkim kopiowaniem."
    },
    "sysmon": {
      "name": "Monitor systemu",
      "desc": "Monitorowanie CPU, pamięci, dysku, sieci i procesów w czasie rzeczywistym z wykresami na żywo."
    },
    "icons": {
      "name": "Eksplorator ikon",
      "desc": "Przeglądaj i wyszukuj ikony Bootstrap Icons, Font Awesome i Tabler Icons. Kliknij, żeby skopiować klasę CSS lub HTML."
    },
    "askai": {
      "name": "Zapytaj AI",
      "desc": "Szybki dostęp do 9 chmurowych AI (Claude, ChatGPT, Gemini itp.) i Ollama z paska nawigacji."
    },
    "translator": {
      "name": "Tłumacz",
      "desc": "Tłumacz tekst między językami za pomocą lokalnych modeli Ollama AI. Jak Google Translate, ale offline."
    }
  },
