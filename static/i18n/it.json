    },
    "netscan": {
      "name": "Scanner di Rete",
      "desc": "Scansiona host e porte nella LAN. Scopri dispositivi, servizi e porte aperte nella tua rete."
    },
    "worldclock": {
      "name": "Orologio Mondiale",
      "desc": "Orologi multi-fuso orario con display analogico, pianificatore riunioni e riordinamento tramite trascinamento."
    },
    "ocr": {
      "name": "OCR",
      "desc": "Estrai testo da immagini e screenshot. Trascina, incolla o carica — basato su Tesseract.js."
    },
    "yaml2props": {
      "name": "YAML ↔ Properties",
      "desc": "Converti tra application.yml e application.properties per progetti Java/Spring Boot."
    },
    "netinspect": {
      "name": "Ispettore di Rete",
      "desc": "Geolocalizzazione IP, ricerca DNS, header di risposta HTTP e verifica certificati SSL."
    },
    "aichat": {
      "name": "Chat AI",
      "desc": "Chatta con modelli AI locali di Ollama. Risposte in streaming, rendering Markdown, cronologia conversazioni."
    },
    "speedtest": {
      "name": "Test di Velocità",
      "desc": "Testa velocità di download/upload, latenza ping e prestazioni di lettura/scrittura del disco."
    },
    "snippets": {
      "name": "Frammenti di Codice",
