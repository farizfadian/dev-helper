    },
    "diff": {
      "name": "So sánh mã",
      "desc": "So sánh hai tệp mã cạnh nhau hoặc xen kẽ với chế độ xem diff tô sáng cú pháp."
    },
    "jwt": {
      "name": "Công cụ JWT",
