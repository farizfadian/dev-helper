    },
    "base64": {
      "name": "Base64",
      "desc": "Mã hóa và giải mã chuỗi Base64. Hỗ trợ văn bản và tệp nhị phân với tùy chọn URL-safe."
    },
    "urlencoder": {
      "name": "Bộ mã hóa URL",
      "desc": "Mã hóa và giải mã URL và tham số truy vấn. Phân tích URL hiển thị giao thức, host, đường dẫn và tham số."
    },
    "htmleditor": {
      "name": "Trình soạn HTML",
      "desc": "Trình soạn văn bản WYSIWYG chạy bằng TinyMCE với chế độ xem mã nguồn HTML."
    },
    "mermaid": {
      "name": "Sơ đồ Mermaid",
      "desc": "Tạo sơ đồ luồng, sơ đồ tuần tự, sơ đồ ER, biểu đồ Gantt và nhiều hơn nữa với Mermaid.js xem trước trực tiếp."
    },
    "uuid": {
      "name": "Trình tạo UUID",
      "desc": "Tạo UUID v1, v4 và v7. Tạo hàng loạt, kiểm tra, phân tích và sao chép với tùy chọn định dạng."
    },
    "notes": {
      "name": "Ghi chú",
      "desc": "Ghi chú Markdown với xem trước trực tiếp, thẻ, danh mục, nhãn màu, tệp đính kèm và tự động lưu."
    },
    "regex": {
      "name": "Kiểm tra regex",
      "desc": "Kiểm tra mẫu regex với tô sáng kết quả thời gian thực, nhóm bắt, thay thế và bảng mẹo."
    },
    "charmap": {
      "name": "Emoji & Bản đồ ký tự",
      "desc": "Tìm kiếm và sao chép emoji, ký hiệu và ký tự đặc biệt. Chi tiết Unicode, thực thể HTML và đã dùng gần đây."
    },
    "epoch": {
      "name": "Chuyển đổi Epoch",
      "desc": "Chuyển đổi dấu thời gian Unix epoch sang ngày dễ đọc và ngược lại. Đồng hồ trực tiếp, mẫu có sẵn và tính chênh lệch thời gian."
    },
    "hash": {
      "name": "Trình tạo Hash",
      "desc": "Tạo hash MD5, SHA-1, SHA-256, SHA-512 từ văn bản hoặc tệp. Xác minh checksum ngay lập tức."
    },
    "colorpicker": {
      "name": "Bộ chọn màu",
      "desc": "Chọn màu và chuyển đổi giữa các định dạng HEX, RGB, HSL. Bảng màu và kiểm tra độ tương phản."
    },
    "cron": {
      "name": "Phân tích cron",
      "desc": "Phân tích và tạo biểu thức cron với mô tả dễ hiểu và thời gian chạy tiếp theo."
    },
    "password": {
      "name": "Trình tạo mật khẩu",
      "desc": "Tạo mật khẩu ngẫu nhiên an toàn bằng mã hóa và cụm mật khẩu dễ nhớ."
    },
    "qrcode": {
      "name": "Trình tạo QR Code",
      "desc": "Tạo QR code từ văn bản, URL, thông tin WiFi hoặc liên hệ. Tải xuống dạng PNG."
    },
    "lorem": {
      "name": "Lorem Ipsum",
      "desc": "Tạo văn bản giữ chỗ — đoạn văn, câu hoặc từ. Có nhiều phong cách khác nhau."
    },
    "baseconverter": {
      "name": "Chuyển đổi cơ số",
      "desc": "Chuyển đổi số giữa các cơ số Nhị phân, Bát phân, Thập phân và Thập lục phân theo thời gian thực."
    },
    "json2yaml": {
      "name": "JSON ↔ YAML",
      "desc": "Chuyển đổi giữa định dạng JSON và YAML với kiểm tra cú pháp và định dạng."
    },
    "httpclient": {
      "name": "HTTP Client",
      "desc": "Kiểm tra API endpoint giống Postman thu nhỏ. Phương thức, header, body tùy chỉnh và xem phản hồi."
    },
    "stringutils": {
      "name": "Tiện ích chuỗi",
      "desc": "Chuyển đổi chữ hoa/thường, cắt khoảng trắng, đếm, đảo ngược, tạo slug và nhiều thao tác chuỗi khác."
    },
    "chat": {
      "name": "Chat LAN",
      "desc": "Chat thời gian thực trong mạng nội bộ. Không cần internet — chỉ cần Dev Helper trên LAN."
    },
    "netscan": {
      "name": "Quét mạng",
      "desc": "Quét host và cổng trên LAN. Phát hiện thiết bị, dịch vụ và cổng mở trên mạng của bạn."
    },
    "worldclock": {
      "name": "Đồng hồ thế giới",
      "desc": "Đồng hồ nhiều múi giờ với hiển thị analog, lên lịch họp và kéo thả sắp xếp."
    },
    "ocr": {
      "name": "OCR",
      "desc": "Trích xuất văn bản từ hình ảnh và ảnh chụp màn hình. Kéo, dán hoặc tải lên — chạy bằng Tesseract.js."
    },
    "yaml2props": {
      "name": "YAML ↔ Properties",
      "desc": "Chuyển đổi giữa application.yml và application.properties cho dự án Java/Spring Boot."
    },
    "netinspect": {
      "name": "Kiểm tra mạng",
      "desc": "Tra cứu vị trí IP, DNS, header phản hồi HTTP và kiểm tra chứng chỉ SSL."
    },
    "aichat": {
      "name": "Chat AI",
      "desc": "Chat với mô hình AI Ollama cục bộ. Phản hồi streaming, hiển thị markdown, lịch sử hội thoại."
    },
    "speedtest": {
      "name": "Kiểm tra tốc độ",
      "desc": "Kiểm tra tốc độ tải xuống/tải lên, độ trễ ping và hiệu suất đọc/ghi ổ đĩa."
    },
    "snippets": {
      "name": "Đoạn mã",
      "desc": "Lưu và sắp xếp các đoạn mã hay dùng với tô sáng cú pháp và sao chép nhanh."
    },
    "sysmon": {
      "name": "Giám sát hệ thống",
      "desc": "Giám sát CPU, bộ nhớ, ổ đĩa, mạng và tiến trình thời gian thực với đồng hồ đo trực tiếp."
    },
    "icons": {
      "name": "Khám phá biểu tượng",
      "desc": "Duyệt và tìm kiếm Bootstrap Icons, Font Awesome và Tabler Icons. Nhấn để sao chép class CSS hoặc HTML."
    },
    "askai": {
      "name": "Hỏi AI",
