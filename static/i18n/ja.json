    },
    "speedtest": {
      "name": "スピードテスト",
      "desc": "ネットワークのダウンロード/アップロード速度、ping レイテンシ、ディスク読み書き性能をテスト。"
    },
    "snippets": {
      "name": "コードスニペット",
