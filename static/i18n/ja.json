    },
    "editor": {
      "name": "コードエディタ",
      "desc": "Monaco（VS Code）搭載のフル機能コードエディタ。40 以上の言語のシンタックスハイライトに対応。"
    },
    "markdown": {
      "name": "Markdown ビューア",
      "desc": "Markdown をリアルタイムプレビューで編集。シンタックスハイライト付きコードブロックと GFM に対応。"
    },
    "diff": {
      "name": "コード差分",
      "desc": "2 つのコードファイルをサイドバイサイドまたはインラインで比較。シンタックスハイライト付き差分表示。"
    },
    "jwt": {
      "name": "JWT ツール",
      "desc": "JSON Web Token のエンコード、デコード、検証。HS256/384/512 対応、カラー表示。"
    },
    "base64": {
      "name": "Base64",
      "desc": "Base64 文字列のエンコードとデコード。テキストとバイナリファイル対応、URL セーフオプション付き。"
    },
    "urlencoder": {
      "name": "URL エンコーダー",
      "desc": "URL とクエリパラメータのエンコード・デコード。URL パーサーでプロトコル、ホスト、パス、パラメータを表示。"
    },
    "htmleditor": {
      "name": "HTML エディタ",
      "desc": "TinyMCE 搭載のリッチテキスト WYSIWYG エディタ。HTML ソースコード表示切り替え付き。"
    },
    "mermaid": {
      "name": "Mermaid ダイアグラム",
      "desc": "Mermaid.js のリアルタイムプレビューでフローチャート、シーケンス図、ER 図、ガントチャートなどを作成。"
    },
    "uuid": {
      "name": "UUID ジェネレーター",
      "desc": "UUID v1、v4、v7 を生成。一括生成、検証、解析、コピー、フォーマットオプション付き。"
    },
    "notes": {
      "name": "ノート",
      "desc": "Markdown ノート。リアルタイムプレビュー、タグ、カテゴリ、カラーラベル、添付ファイル、自動保存に対応。"
    },
    "regex": {
      "name": "Regex テスター",
      "desc": "リアルタイムマッチハイライトで regex パターンをテスト。キャプチャグループ、置換、チートシート付き。"
    },
    "charmap": {
      "name": "絵文字＆文字マップ",
      "desc": "絵文字、記号、特殊文字を検索してコピー。Unicode 詳細、HTML エンティティ、最近使った文字を表示。"
    },
    "epoch": {
      "name": "エポック変換器",
      "desc": "Unix エポックタイムスタンプと人間が読める日付を相互変換。ライブクロック、プリセット、時間差計算機付き。"
    },
    "hash": {
      "name": "ハッシュジェネレーター",
      "desc": "テキストやファイルから MD5、SHA-1、SHA-256、SHA-512 ハッシュを生成。チェックサムを即座に検証。"
    },
    "colorpicker": {
      "name": "カラーピッカー",
      "desc": "色を選択して HEX、RGB、HSL フォーマット間で変換。カラーパレットとコントラストチェッカー付き。"
    },
    "cron": {
      "name": "Cron パーサー",
      "desc": "cron 式の解析と生成。人間が読める説明と次回実行時間を表示。"
    },
    "password": {
      "name": "パスワードジェネレーター",
      "desc": "暗号学的に安全なランダムパスワードと覚えやすいパスフレーズを生成。"
    },
    "qrcode": {
      "name": "QR コードジェネレーター",
      "desc": "テキスト、URL、WiFi 認証情報、連絡先から QR コードを生成。PNG でダウンロード。"
    },
    "lorem": {
      "name": "Lorem Ipsum",
      "desc": "プレースホルダーテキストを生成 — 段落、文、単語。複数のスタイルから選択可能。"
    },
    "baseconverter": {
      "name": "基数変換器",
      "desc": "2 進数、8 進数、10 進数、16 進数間でリアルタイムに数値を変換。"
    },
    "json2yaml": {
      "name": "JSON ↔ YAML",
      "desc": "JSON と YAML フォーマット間の相互変換。構文検証とフォーマット付き。"
    },
    "httpclient": {
      "name": "HTTP クライアント",
      "desc": "ミニ Postman のように API エンドポイントをテスト。メソッド、ヘッダー、ボディ、レスポンスビューアをカスタマイズ。"
    },
    "stringutils": {
      "name": "文字列ユーティリティ",
      "desc": "大文字小文字変換、トリム、カウント、反転、slug 生成など多数の文字列操作。"
    },
    "chat": {
      "name": "LAN チャット",
      "desc": "ローカルネットワーク用リアルタイムチャット。インターネット不要 — LAN 上の Dev Helper だけで OK。"
    },
    "netscan": {
      "name": "ネットワークスキャナー",
      "desc": "LAN ホストとポートをスキャン。ネットワーク上のデバイス、サービス、オープンポートを検出。"
    },
    "worldclock": {
      "name": "世界時計",
      "desc": "アナログ表示付きマルチタイムゾーン時計。会議プランナーとドラッグ並べ替え対応。"
    },
    "ocr": {
      "name": "OCR",
      "desc": "画像やスクリーンショットからテキストを抽出。ドラッグ、貼り付け、アップロードに対応。Tesseract.js 搭載。"
    },
    "yaml2props": {
      "name": "YAML ↔ Properties",
