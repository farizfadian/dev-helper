    },
    "netinspect": {
      "name": "ネットワークインスペクター",
      "desc": "IP ジオロケーション、DNS ルックアップ、HTTP レスポンスヘッダー、SSL 証明書チェッカー。"
    },
    "aichat": {
      "name": "AI チャット",
