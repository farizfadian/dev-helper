  "tools": {
    "upload": {
      "name": "Upload",
      "desc": "Arraste, solte, cole ou procure arquivos para enviar. Prévia de imagens com lightbox."
    },
    "files": {
      "name": "Explorador de Arquivos",
      "desc": "Navegue, busque e gerencie arquivos enviados em uma visualização em grade estilo Google Drive."
    },
    "prettify": {
      "name": "Prettify",
      "desc": "Formate e embeleze código JSON, XML, HTML, CSS, JavaScript e SQL."
    },
    "logs": {
      "name": "Agregador de Logs",
      "desc": "Coletor leve de logs. Receba logs de qualquer app via HTTP POST, filtre por app e nível."
    },
    "logviewer": {
      "name": "Visualizador de Logs",
      "desc": "Envie e pesquise arquivos de log grandes com filtragem por palavra-chave, regex e linhas de contexto."
    },
    "editor": {
      "name": "Editor de Código",
      "desc": "Editor de código completo baseado em Monaco (VS Code). Destaque de sintaxe para mais de 40 linguagens."
    },
    "markdown": {
      "name": "Visualizador Markdown",
      "desc": "Escreva Markdown com prévia ao vivo, blocos de código com destaque de sintaxe e suporte a GFM."
    },
    "diff": {
      "name": "Comparador de Código",
      "desc": "Compare dois arquivos de código lado a lado ou em linha com visualização de diff com destaque de sintaxe."
    },
    "jwt": {
      "name": "Ferramenta JWT",
      "desc": "Codifique, decodifique e verifique JSON Web Tokens. Suporta HS256/384/512 com exibição colorida."
    },
    "base64": {
      "name": "Base64",
      "desc": "Codifique e decodifique strings Base64. Suporta texto e arquivos binários com opção URL-safe."
    },
    "urlencoder": {
      "name": "Codificador de URL",
      "desc": "Codifique e decodifique URLs e parâmetros de consulta. O parser de URL mostra protocolo, host, caminho e parâmetros."
    },
    "htmleditor": {
      "name": "Editor HTML",
      "desc": "Editor de texto rico WYSIWYG baseado em TinyMCE com alternância para visualização do código-fonte HTML."
    },
    "mermaid": {
      "name": "Diagrama Mermaid",
      "desc": "Crie fluxogramas, diagramas de sequência, diagramas ER, gráficos de Gantt e mais com prévia ao vivo do Mermaid.js."
    },
    "uuid": {
      "name": "Gerador de UUID",
      "desc": "Gere UUID v1, v4 e v7. Geração em massa, validação, análise e cópia com opções de formato."
    },
    "notes": {
      "name": "Notas",
      "desc": "Notas em Markdown com prévia ao vivo, tags, categorias, etiquetas coloridas, anexos e salvamento automático."
    },
    "regex": {
      "name": "Testador de Regex",
      "desc": "Teste padrões regex com destaque de correspondências em tempo real, grupos de captura, substituição e guia rápido."
    },
    "charmap": {
      "name": "Emoji e Mapa de Caracteres",
      "desc": "Busque e copie emojis, símbolos e caracteres especiais. Detalhes Unicode, entidades HTML e usados recentemente."
    },
    "epoch": {
      "name": "Conversor Epoch",
      "desc": "Converta timestamps Unix epoch para datas legíveis e vice-versa. Relógio ao vivo, predefinições e calculadora de diferença de tempo."
    },
    "hash": {
      "name": "Gerador de Hash",
      "desc": "Gere hashes MD5, SHA-1, SHA-256, SHA-512 a partir de texto ou arquivos. Verifique checksums instantaneamente."
    },
    "colorpicker": {
      "name": "Seletor de Cores",
      "desc": "Selecione cores e converta entre formatos HEX, RGB, HSL. Paleta de cores e verificador de contraste."
    },
    "cron": {
      "name": "Parser de Cron",
      "desc": "Analise e gere expressões cron com descrições legíveis e próximos horários de execução."
    },
    "password": {
      "name": "Gerador de Senhas",
      "desc": "Gere senhas aleatórias criptograficamente seguras e frases-senha memoráveis."
    },
    "qrcode": {
      "name": "Gerador de QR Code",
      "desc": "Gere QR codes a partir de texto, URLs, credenciais WiFi ou informações de contato. Baixe como PNG."
    },
    "lorem": {
      "name": "Lorem Ipsum",
      "desc": "Gere texto de preenchimento — parágrafos, frases ou palavras. Vários estilos disponíveis."
    },
    "baseconverter": {
      "name": "Conversor de Bases",
      "desc": "Converta números entre bases Binária, Octal, Decimal e Hexadecimal em tempo real."
    },
    "json2yaml": {
      "name": "JSON ↔ YAML",
      "desc": "Converta entre formatos JSON e YAML com validação de sintaxe e formatação."
    },
    "httpclient": {
      "name": "Cliente HTTP",
      "desc": "Teste endpoints de API como um mini Postman. Métodos, headers, body e visualizador de resposta personalizados."
    },
    "stringutils": {
      "name": "Utilitários de String",
      "desc": "Conversor de caixa, trim, contagem, inverter, gerador de slug e mais operações com strings."
    },
    "chat": {
      "name": "Chat LAN",
      "desc": "Chat em tempo real para sua rede local. Sem internet necessária — apenas Dev Helper na LAN."
    },
    "netscan": {
      "name": "Scanner de Rede",
      "desc": "Escaneie hosts e portas na LAN. Descubra dispositivos, serviços e portas abertas na sua rede."
    },
    "worldclock": {
      "name": "Relógio Mundial",
      "desc": "Relógios de múltiplos fusos horários com display analógico, planejador de reuniões e reordenação por arrastar."
    },
    "ocr": {
      "name": "OCR",
      "desc": "Extraia texto de imagens e capturas de tela. Arraste, cole ou envie — powered by Tesseract.js."
    },
    "yaml2props": {
      "name": "YAML ↔ Properties",
      "desc": "Converta entre application.yml e application.properties para projetos Java/Spring Boot."
    },
    "netinspect": {
      "name": "Inspetor de Rede",
      "desc": "Geolocalização de IP, consulta DNS, headers de resposta HTTP e verificador de certificado SSL."
    },
    "aichat": {
      "name": "Chat com IA",
      "desc": "Converse com modelos de IA locais do Ollama. Respostas em streaming, renderização Markdown, histórico de conversas."
    },
    "speedtest": {
      "name": "Teste de Velocidade",
      "desc": "Teste velocidade de download/upload, latência de ping e desempenho de leitura/escrita do disco."
    },
    "snippets": {
      "name": "Trechos de Código",
      "desc": "Salve e organize trechos de código usados com frequência com destaque de sintaxe e cópia rápida."
    },
    "sysmon": {
      "name": "Monitor do Sistema",
      "desc": "Monitoramento em tempo real de CPU, memória, disco, rede e processos com medidores ao vivo."
    },
    "icons": {
      "name": "Explorador de Ícones",
      "desc": "Navegue e busque Bootstrap Icons, Font Awesome e Tabler Icons. Clique para copiar classe CSS ou HTML."
    },
    "askai": {
      "name": "Perguntar à IA",
      "desc": "Acesso rápido a 9 IAs na nuvem (Claude, ChatGPT, Gemini, etc.) e Ollama pela barra de navegação."
    },
    "translator": {
      "name": "Tradutor",
      "desc": "Traduza texto entre idiomas usando modelos de IA locais do Ollama. Como o Google Translate, mas offline."
    }
