  "tools": {
    "upload": {
      "name": "Yükleme",
      "desc": "Dosyaları sürükle & bırak, yapıştır veya gözat ile yükleyin. Resim önizlemesi ve lightbox."
    },
    "files": {
      "name": "Dosya Gezgini",
      "desc": "Yüklenen dosyalara Google Drive benzeri ızgara görünümünde göz atın, arayın ve yönetin."
    },
    "prettify": {
      "name": "Prettify",
      "desc": "JSON, XML, HTML, CSS, JavaScript ve SQL kodlarını biçimlendirin ve güzelleştirin."
    },
    "logs": {
      "name": "Log Toplayıcı",
      "desc": "Hafif log toplayıcı. Herhangi bir uygulamadan HTTP POST ile log alın, uygulama ve seviyeye göre filtreleyin."
    },
    "logviewer": {
      "name": "Log Görüntüleyici",
      "desc": "Büyük log dosyalarını yükleyin, anahtar kelime filtreleme, regex ve bağlam satırları ile arama yapın."
    },
    "editor": {
      "name": "Kod Editörü",
      "desc": "Monaco (VS Code) destekli tam donanımlı kod editörü. 40'tan fazla dilde sözdizimi renklendirme."
    },
    "markdown": {
      "name": "Markdown Görüntüleyici",
      "desc": "Canlı önizleme, sözdizimi renkli kod blokları ve GFM desteği ile Markdown yazın."
    },
    "diff": {
      "name": "Kod Farkı",
      "desc": "İki kod dosyasını sözdizimi renkli fark görünümünde yan yana veya satır içi karşılaştırın."
    },
    "jwt": {
      "name": "JWT Aracı",
      "desc": "JSON Web Token'ları kodlayın, çözün ve doğrulayın. HS256/384/512 desteği ile renkli görünüm."
    },
    "base64": {
      "name": "Base64",
      "desc": "Base64 dizelerini kodlayın ve çözün. Metin ve ikili dosya desteği, URL güvenli seçeneği."
    },
    "urlencoder": {
      "name": "URL Kodlayıcı",
      "desc": "URL'leri ve sorgu parametrelerini kodlayın ve çözün. URL ayrıştırıcı: protokol, host, yol ve parametreler."
    },
    "htmleditor": {
      "name": "HTML Editörü",
      "desc": "TinyMCE destekli zengin metin WYSIWYG editörü, HTML kaynak kodu görünümü değiştirme ile."
    },
    "mermaid": {
      "name": "Mermaid Diyagram",
      "desc": "Mermaid.js canlı önizleme ile akış şemaları, sıra diyagramları, ER diyagramları, Gantt grafikleri ve daha fazlasını oluşturun."
    },
    "uuid": {
      "name": "UUID Oluşturucu",
      "desc": "UUID v1, v4 ve v7 oluşturun. Toplu oluşturma, doğrulama, ayrıştırma ve biçim seçenekleri ile kopyalama."
    },
    "notes": {
      "name": "Notlar",
      "desc": "Canlı önizleme, etiketler, kategoriler, renk işaretleri, ekler ve otomatik kayıt ile Markdown notlar."
    },
    "regex": {
      "name": "Regex Test",
      "desc": "Gerçek zamanlı eşleşme vurgulama, yakalama grupları, değiştirme ve kopya kağıdı ile regex kalıplarını test edin."
    },
    "charmap": {
      "name": "Emoji & Karakter Haritası",
      "desc": "Emoji, sembol ve özel karakterleri arayın ve kopyalayın. Unicode detayları, HTML varlıkları ve son kullanılanlar."
    },
    "epoch": {
      "name": "Epoch Dönüştürücü",
      "desc": "Unix epoch zaman damgalarını okunabilir tarihe ve tersine dönüştürün. Canlı saat, hazır ayarlar ve zaman farkı hesaplayıcı."
    },
    "hash": {
      "name": "Hash Oluşturucu",
      "desc": "Metinden veya dosyadan MD5, SHA-1, SHA-256, SHA-512 hash'leri oluşturun. Sağlama toplamlarını anında doğrulayın."
    },
    "colorpicker": {
      "name": "Renk Seçici",
      "desc": "Renk seçin ve HEX, RGB, HSL formatları arasında dönüştürün. Renk paleti ve kontrast denetleyici."
    },
    "cron": {
      "name": "Cron Ayrıştırıcı",
      "desc": "cron ifadelerini okunabilir açıklamalar ve sonraki çalışma zamanları ile ayrıştırın ve oluşturun."
    },
    "password": {
      "name": "Şifre Oluşturucu",
      "desc": "Kriptografik olarak güvenli rastgele şifreler ve akılda kalıcı parola öbekleri oluşturun."
    },
    "qrcode": {
      "name": "QR Kod Oluşturucu",
      "desc": "Metin, URL, WiFi kimlik bilgileri veya kişi bilgisinden QR kod oluşturun. PNG olarak indirin."
    },
    "lorem": {
      "name": "Lorem Ipsum",
      "desc": "Yer tutucu metin oluşturun — paragraf, cümle veya kelime. Birden fazla stil mevcut."
    },
    "baseconverter": {
      "name": "Taban Dönüştürücü",
      "desc": "Sayıları gerçek zamanlı olarak Binary, Octal, Decimal ve Hexadecimal tabanlar arasında dönüştürün."
    },
    "json2yaml": {
      "name": "JSON ↔ YAML",
      "desc": "Sözdizimi doğrulama ve biçimlendirme ile JSON ve YAML formatları arasında dönüştürün."
    },
    "httpclient": {
      "name": "HTTP İstemci",
      "desc": "Mini Postman gibi API uç noktalarını test edin. Özel yöntemler, başlıklar, gövde ve yanıt görüntüleyici."
    },
    "stringutils": {
      "name": "Metin Araçları",
      "desc": "Büyük/küçük harf dönüştürücü, kırpma, sayma, ters çevirme, slug oluşturucu ve daha fazla metin işlemi."
    },
    "chat": {
      "name": "LAN Sohbet",
      "desc": "Yerel ağınız için gerçek zamanlı sohbet. İnternete gerek yok — sadece LAN üzerinde Dev Helper."
    },
    "netscan": {
      "name": "Ağ Tarayıcı",
      "desc": "LAN ana bilgisayarlarını ve portlarını tarayın. Ağınızdaki cihazları, servisleri ve açık portları keşfedin."
    },
    "worldclock": {
      "name": "Dünya Saati",
      "desc": "Analog ekranlı çoklu saat dilimi saatleri, toplantı planlayıcısı ve sürükle-bırak sıralama."
    },
    "ocr": {
      "name": "OCR",
      "desc": "Resim ve ekran görüntülerinden metin çıkarın. Sürükleyin, yapıştırın veya yükleyin — Tesseract.js ile çalışır."
    },
    "yaml2props": {
      "name": "YAML ↔ Properties",
      "desc": "Java/Spring Boot projeleri için application.yml ve application.properties arasında dönüştürme."
    },
    "netinspect": {
      "name": "Ağ Denetçisi",
      "desc": "IP konum belirleme, DNS sorgusu, HTTP yanıt başlıkları ve SSL sertifika denetleyici."
    },
    "aichat": {
      "name": "AI Sohbet",
      "desc": "Yerel Ollama AI modelleri ile sohbet edin. Akış yanıtları, Markdown görüntüleme, konuşma geçmişi."
    },
    "speedtest": {
      "name": "Hız Testi",
      "desc": "Ağ indirme/yükleme hızını, ping gecikmesini ve disk okuma/yazma performansını test edin."
    },
    "snippets": {
      "name": "Kod Parçacıkları",
      "desc": "Sık kullanılan kod parçacıklarını sözdizimi renklendirme ve hızlı kopyalama ile kaydedin ve düzenleyin."
    },
    "sysmon": {
      "name": "Sistem Monitörü",
      "desc": "Canlı göstergelerle gerçek zamanlı CPU, bellek, disk, ağ ve süreç izleme."
    },
    "icons": {
      "name": "İkon Gezgini",
      "desc": "Bootstrap Icons, Font Awesome ve Tabler Icons'a göz atın ve arayın. CSS sınıfını veya HTML'i kopyalamak için tıklayın."
    },
    "askai": {
      "name": "AI'a Sor",
      "desc": "Gezinme çubuğundan 9 bulut AI'a (Claude, ChatGPT, Gemini, vb.) ve Ollama'ya hızlı erişim."
    },
    "translator": {
      "name": "Çevirmen",
      "desc": "Yerel Ollama AI modelleri ile diller arası metin çevirisi. Google Translate gibi, çevrimdışı."
    }
